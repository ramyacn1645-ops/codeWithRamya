def categorize_ratings(rating_list):
    # YOUR CODE HERE
    low = 0
    medium = 0
    high =0 
    
    for i in rating_list:
    
        if 1<=i<=4:
            low +=1
            
        elif 5<=i<=7:
            medium +=1
           
        elif 8<=i<=10:
            high +=1
        else:
            print("Enter the ratings in between 1 and 10")
    print("Low:",low)
    print("Medium:",medium)
    print("High:",high)
     
categorize_ratings([1, 3, 5, 7, 8, 9])