
# list and it's operatrions

#create a list 
l1 = [1,2,'apple','banana']
# accessing elements through indexing
l2 = l1[0]
print(l2)  # positive indexing
l3 = l1[-1]
print(l3)  # negative indexing
# accesing part or subset or list using slicing
l4 = l1[0::1]
print(l4)



# example for dictionary 
student = {
    "name": "Ramya",
    "age": 20,
    "course": "Python"
}

# adding and updating dictionary values
student["age"] = 21            # Update
student["college"] = "XYZ"     # Add new key
# removing elements
student.pop("age")        # Removes age
del student["course"]     # Deletes course

# looping through dictionary 
for key in student:
    print(key, student[key])
# another way of looping
for key, value in student.items():
    print(key, value)



